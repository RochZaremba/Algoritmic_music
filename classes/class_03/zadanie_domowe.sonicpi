use_bpm 118

steps = 0

live_loop :clock do
  cue :bar
  sleep 4
end

live_loop :drums do
  sync :bar

  4.times do
    sample :bd_haus, amp: 1.8
    sleep 0.75
    sample :elec_tick, amp: 0.5
    sleep 0.25
    sample :sn_dub, amp: 0.9
    sleep 0.5
    sample :elec_tick, amp: 0.4
    sleep 0.5
    steps += 1
  end

  stop if steps >= 8
end
